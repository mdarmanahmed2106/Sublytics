# ── Server Configuration ──
PORT=5000
NODE_ENV=development

# ── MongoDB ──
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/sublytics?retryWrites=true&w=majority

# ── JWT (Access Token) ──
JWT_SECRET=CHANGE_ME_to_a_strong_random_string
JWT_EXPIRE=15m

# ── JWT (Refresh Token) ──
JWT_REFRESH_SECRET=CHANGE_ME_to_a_different_strong_random_string
JWT_REFRESH_EXPIRE=30d

# ── Frontend URL (for CORS) ──
CLIENT_URL=http://localhost:5173
